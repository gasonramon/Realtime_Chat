{
  "db_name": "PostgreSQL",
  "query": "SELECT m.id, m.sender_id, u.name as sender_name, m.encrypted_content, m.recipients, m.created_at, m.room, m.expires_at\n           FROM messages m\n           JOIN users u ON u.id = m.sender_id\n           WHERE (m.room = 'global' OR m.sender_id = $1 OR $1 = ANY(m.recipients))\n             AND m.expires_at > NOW()\n           ORDER BY m.created_at DESC\n           LIMIT 50",
